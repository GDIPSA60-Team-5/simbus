<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/RoutePageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Route"
        android:textSize="30dp"
        android:layout_marginTop="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <TextView
        android:id="@+id/FromText"
        android:layout_width="50dp"
        android:layout_height="20dp"
        android:text="From:"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/RoutePageTitle"
        app:layout_constraintStart_toStartOf="parent"
        />
    <EditText
        android:id="@+id/FromEdit"
        android:layout_width="100dp"
        android:layout_marginTop="10dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/FromText"
        app:layout_constraintTop_toBottomOf="@id/RoutePageTitle"
        />

    <TextView
        android:id="@+id/ToText"
        android:layout_width="50dp"
        android:layout_height="20dp"
        android:layout_marginTop="36dp"
        android:layout_marginLeft="15dp"
        android:text="To:"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/FromText" />

    <EditText
        android:id="@+id/ToEdit"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toEndOf="@id/ToText"
        app:layout_constraintTop_toBottomOf="@id/FromText" />

    <TextView
        android:id="@+id/BusStopText"
        android:layout_width="70dp"
        android:layout_height="20dp"
        android:text="Bus Stop:"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="36dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ToText"
        />
    <EditText
        android:id="@+id/BusStopEdit"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        android:inputType="none"
        android:textSize="15dp"
        app:layout_constraintStart_toEndOf="@id/BusStopText"
        app:layout_constraintTop_toBottomOf="@id/ToText"
        />

    <Button
        android:id="@+id/BusStopButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Bus Stop"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/ToText"
        app:layout_constraintStart_toEndOf="@id/BusStopEdit"
        />


    <TextView
        android:id="@+id/BusServiceText"
        android:layout_width="80dp"
        android:layout_height="20dp"
        android:text="Bus Service:"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="36dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/BusStopText"
        />
    <EditText
        android:id="@+id/BusServiceEdit"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:cursorVisible="false"
        android:inputType="none"
        app:layout_constraintStart_toEndOf="@+id/BusServiceText"
        app:layout_constraintTop_toBottomOf="@+id/BusStopText"
        />
    <Button
        android:id="@+id/BusServiceButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Bus Service"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toEndOf="@id/BusServiceEdit"
        app:layout_constraintTop_toBottomOf="@id/BusStopText"
        />


    <TextView
        android:id="@+id/StartTimeText"
        android:layout_width="60dp"
        android:layout_height="20dp"
        android:text="Start at:"
        android:layout_marginTop="36dp"
        android:layout_marginLeft="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/BusServiceText"
        />
    <EditText
        android:id="@+id/StartTimeEdit"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        app:layout_constraintStart_toEndOf="@id/StartTimeText"
        app:layout_constraintTop_toBottomOf="@id/BusServiceText"
        />

    <TextView
        android:id="@+id/ArrivalTimeText"
        android:layout_width="60dp"
        android:layout_height="20dp"
        android:text="Arrive at: "
        android:layout_marginTop="36dp"
        android:layout_marginLeft="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/StartTimeText"
        />
    <EditText
        android:id="@+id/ArrivalTimeEdit"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        app:layout_constraintStart_toEndOf="@id/ArrivalTimeText"
        app:layout_constraintTop_toBottomOf="@id/StartTimeText"
        />
    <TextView
        android:id="@+id/DaysFrequencyText"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:text="Days:"
        android:layout_marginTop="36dp"
        android:layout_marginLeft="15dp"
        app:layout_constraintTop_toBottomOf="@+id/ArrivalTimeText"
        app:layout_constraintStart_toStartOf="parent"
        >
    </TextView>

    <LinearLayout
        android:id="@+id/FrequencyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/DaysFrequencyText">

        <CheckBox
            android:id="@+id/MonCheck"
            android:text="M"
            style="@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/TuesCheck"
            android:text="T"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/WedCheck"
            android:text="W"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/ThursCheck"
            android:text="T"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/FriCheck"
            android:text="F"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/SatCheck"
            android:text="S"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
        <CheckBox
            android:id="@+id/SunCheck"
            android:text="S"
            style = "@style/DayToggle"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            />
    </LinearLayout>

    <TextView
        android:id="@+id/frequencyError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone"
        android:text="Please select at least one day"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/FrequencyLayout"
        />


    <Button
        android:id="@+id/RouteCancelButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:layout_marginLeft="75dp"
        android:layout_marginBottom="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />
    <Button
        android:id="@+id/RouteSaveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginBottom="50dp"
        android:layout_marginRight="75dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

</androidx.constraintlayout.widget.ConstraintLayout>